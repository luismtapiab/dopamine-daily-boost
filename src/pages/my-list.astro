---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/dopamine-daily-boost/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>Customize Activities — Dopamine Daily Boost</title>
  <meta name="description" content="Add your own custom activities and adjust their healthy/not weight tags for your daily roulette." />
  <!-- Preload Pico CSS -->
  <link rel="preload" href="/dopamine-daily-boost/node_modules/@picocss/pico/css/pico.min.css" as="style" onload="this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/dopamine-daily-boost/node_modules/@picocss/pico/css/pico.min.css"></noscript>
  <!-- Custom CSS (global) -->
  <link rel="stylesheet" href="/dopamine-daily-boost/src/styles/global.css">
</head>
<body>
  <main class="container" style="padding-top: 1rem; padding-bottom: 2rem;">
    <nav style="margin-bottom: 1.5rem;">
      <ul>
        <li>
          <a href="/dopamine-daily-boost/" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
            <strong style="color: var(--primary); font-size: 1.3rem;">⚡ Daily Boost</strong>
          </a>
        </li>
      </ul>
      <ul style="align-items: center; gap: 0.5rem;">
        <li><a href="/dopamine-daily-boost/">Spin</a></li>
        <li><a href="/dopamine-daily-boost/log/">History</a></li>
        <li><a href="/dopamine-daily-boost/my-list/" class="active">Customize</a></li>
        <li style="border-left: 1px solid var(--card-border-color); padding-left: 0.75rem; margin-left: 0.25rem;"><div id="streak-badge-root"></div></li>
      </ul>
    </nav>

    <header style="margin-bottom: 1.5rem;">
      <h2 style="margin-bottom: 0.25rem;">Customize Your Wheel</h2>
      <p style="color: var(--muted-color); font-size: 1rem; margin-bottom: 0;">
        Add your own custom things. Tag them as healthy or treat to balance the random odds.
      </p>
    </header>

    <section>
      <div id="custom-list-manager-root"></div>
    </section>

    <footer style="margin-top: 2rem; text-align: center; border-top: 1px solid var(--card-border-color); padding-top: 1rem;">
      <p style="color: var(--muted-color); font-size: 0.85rem; margin-bottom: 0.5rem;">
        "Make something instead for a try, better if that thing demands more than a few minutes."
      </p>
      <div style="font-size: 0.85rem; color: var(--muted-color);">
        Concept by <strong>luismtapiab</strong> • <a href="/dopamine-daily-boost/about" style="text-decoration: underline;">About the Philosophy</a>
      </div>
    </footer>
  </main>

  <script>
    import { h, render } from 'preact';
    import StreakBadge from '../components/StreakBadge';
    import CustomListManager from '../components/CustomListManager';

    const streakRoot = document.getElementById('streak-badge-root');
    if (streakRoot) {
      render(h(StreakBadge, {}), streakRoot);
    }

    const customRoot = document.getElementById('custom-list-manager-root');
    if (customRoot) {
      render(h(CustomListManager, {}), customRoot);
    }
  </script>
</body>
</html>
